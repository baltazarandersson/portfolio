{
	"name": "portfolio-astro",
	"type": "module",
	"version": "2.2.0",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "yarn run check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "astro check",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
