		"svelte": "^5.56.2"
	},
	"optionalDependencies": {
		"@img/sharp-libvips-linux-x64": "1.2.4",
		"@img/sharp-linux-x64": "0.34.5"
	},
	"resolutions": {
		"sharp": "0.34.5"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"cspell": "^10.0.1",
		"husky": "^9.1.7",
		"prettier": "^3.6.2",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"tailwindcss": "^3.4.19",
		"typescript": "^6.0.3"
