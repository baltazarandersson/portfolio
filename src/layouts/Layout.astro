---
import BgBall from '@components/BgBall.svelte'
import Header from '@components/Header/index.astro'
import StarryBackground from '@components/StarryBackground.svelte'
interface Props {
	title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Baltazar Andersson's portfolio, made with AstroJS in addition with Svelte and TailwindCSS."
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="scroll-smooth bg-surface font-helvetica text-foreground">
		<StarryBackground client:only />
		<Header />
		<slot />
		<BgBall client:only />
	</body>
	<script>
		import { getCurrentTheme, updateStoredTheme } from '@utils/theme'
		import type { ThemeType } from 'types/index'

		const theme = (() => getCurrentTheme())() as ThemeType

		if (theme === 'light') {
			document.documentElement.classList.remove('dark')
		}

		updateStoredTheme(theme)
	</script>
</html>
<style is:global>
	@font-face {
		font-family: 'Heming Variable';
		src: url('/fonts/heming_variable.ttf') format('woff');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'Helvetica Light';
		src: url('/fonts/helvetica_light.woff') format('woff');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	:root {
		--color-primary: 245 158 11;
		--color-accent: 217 119 6;
		--color-focus: 245 158 11;
		--color-surface: 244 244 245;
		--color-surface-muted: 228 228 231;
		--color-surface-elevated: 250 250 250;
		--color-border: 212 212 216;
		--color-text: 63 63 70;
		--color-text-muted: 113 113 122;
		--primary-color: rgb(var(--color-primary));
	}

	:root.dark {
		--color-primary: 217 119 6;
		--color-accent: 251 191 36;
		--color-focus: 251 191 36;
		--color-surface: 24 24 27;
		--color-surface-muted: 39 39 42;
		--color-surface-elevated: 63 63 70;
		--color-border: 63 63 70;
		--color-text: 238 242 255;
		--color-text-muted: 161 161 170;
		--primary-color: rgb(var(--color-primary));
	}

	:root[class='dark'] {
		color-scheme: dark;
	}

	html {
		scroll-behavior: smooth;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}

	* {
		-webkit-tap-highlight-color: transparent; /* remove tap highlight */
	}

	:where(a, button, input, textarea, select, summary, [tabindex]):focus-visible {
		outline: 2px solid rgb(var(--color-focus) / 0.95);
		outline-offset: 3px;
	}

	.p-layout {
		@apply px-8 sm:px-12 md:px-20 lg:px-40 xl:px-40;
	}
</style>
