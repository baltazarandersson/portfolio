---
import BgBall from '@components/BgBall.svelte'
import Header from '@components/Header/index.astro'
import StarryBackground from '@components/StarryBackground.svelte'
import { ClientRouter } from 'astro:transitions'
interface Props {
	title: string
	lang?: 'en' | 'es'
	description?: string
	image?: string
	type?: 'website' | 'article'
}

const DEFAULT_DESCRIPTION =
	"Baltazar Andersson's portfolio, made with AstroJS in addition with Svelte and TailwindCSS."
const DEFAULT_IMAGE = '/images/og/default.webp'

const {
	title,
	lang = 'en',
	description = DEFAULT_DESCRIPTION,
	image = DEFAULT_IMAGE,
	type = 'website'
} = Astro.props

// Absolute URLs are required by social crawlers (LinkedIn, X) for og:image and og:url.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href
const imageUrl = new URL(image, Astro.site).href
---

<!doctype html>
<html lang={lang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="favicon.ico" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph (LinkedIn, Facebook) -->
		<meta property="og:type" content={type} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:site_name" content="Baltazar Andersson" />
		<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<script is:inline>
			// Apply the stored theme before paint, on first load and after every
			// view-transition swap (ClientRouter resets <html> to its static class).
			const applyStoredTheme = () => {
				const stored = localStorage.getItem('theme')
				const theme = stored === 'light' || stored === 'dark' ? stored : 'dark'
				document.documentElement.classList.toggle('dark', theme === 'dark')
				if (!stored) localStorage.setItem('theme', theme)
			}
			applyStoredTheme()
			document.addEventListener('astro:after-swap', applyStoredTheme)
		</script>
		<ClientRouter />
	</head>
	<body class="scroll-smooth bg-surface font-helvetica text-foreground">
		<StarryBackground client:only />
		<Header />
		<slot />
		<BgBall client:only />
	</body>
</html>
<style is:global>
	@font-face {
		font-family: 'Heming Variable';
		src: url('/fonts/heming_variable.ttf') format('woff');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'Helvetica Light';
		src: url('/fonts/helvetica_light.woff') format('woff');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	:root {
		/* Warm "sunset" accents — Gruvbox orange.
		   primary = faded #af3a03 (AA-legible as text on the sand bg),
		   accent/focus = bright neutral #d65d0e for fills, rings & hovers. */
		--color-primary: 175 58 3;
		--color-accent: 214 93 14;
		--color-focus: 214 93 14;
		/* Gruvbox light neutrals — deeper, warmer sand (bg0/bg1/bg2/bg3) */
		--color-surface: 235 219 178;
		--color-surface-muted: 213 196 161;
		--color-surface-elevated: 251 241 199;
		--color-border: 189 174 147;
		/* Warm dark-brown text (fg1) + muted (fg4) */
		--color-text: 60 56 54;
		--color-text-muted: 124 111 100;
		--primary-color: rgb(var(--color-primary));
	}

	:root.dark {
		--color-primary: 217 119 6;
		--color-accent: 251 191 36;
		--color-focus: 251 191 36;
		--color-surface: 24 24 27;
		--color-surface-muted: 39 39 42;
		--color-surface-elevated: 63 63 70;
		--color-border: 63 63 70;
		--color-text: 238 242 255;
		--color-text-muted: 161 161 170;
		--primary-color: rgb(var(--color-primary));
	}

	:root[class='dark'] {
		color-scheme: dark;
	}

	html {
		scroll-behavior: smooth;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}

	* {
		-webkit-tap-highlight-color: transparent; /* remove tap highlight */
	}

	:where(a, button, input, textarea, select, summary, [tabindex]):focus-visible {
		outline: 2px solid rgb(var(--color-focus) / 0.95);
		outline-offset: 3px;
	}

	.p-layout {
		@apply px-8 sm:px-12 md:px-20 lg:px-40 xl:px-40;
	}
</style>
