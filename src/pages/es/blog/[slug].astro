---
import Layout from '@layouts/Layout.astro'
import PostArticle from '@components/Blog/PostArticle.astro'
import { getBlogStaticPaths, getPostAlternates } from '@i18n/blog'

export async function getStaticPaths() {
	return getBlogStaticPaths('es')
}

const { post } = Astro.props
const alternates = await getPostAlternates(post)
---

<Layout
	title={`${post.data.title} | Baltazar Andersson`}
	description={post.data.description}
	image={post.data.heroImage}
	type="article"
	alternates={alternates}
>
	<PostArticle post={post} />
</Layout>
