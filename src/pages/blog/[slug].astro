---
import Layout from '@layouts/Layout.astro'
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import Container from '@components/Container.astro'
import ArticleHeader from '@components/Blog/ArticleHeader.astro'
import Prose from '@components/Blog/Prose.astro'
import TableOfContents from '@components/Blog/TableOfContents.astro'

type Props = {
	post: CollectionEntry<'blog'>
}

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft)

	return posts.map((post) => ({
		params: { slug: post.id.replace(/\.md$/, '') },
		props: { post }
	}))
}

const { post } = Astro.props
const { Content, headings } = await render(post)

const tableOfContentsItems = headings
	.filter((heading) => heading.depth === 2)
	.map((heading) => ({ id: heading.slug, label: heading.text }))

const hasToc = tableOfContentsItems.length > 0
---

<Layout title={`${post.data.title} | Baltazar Andersson`}>
	<Container
		as="main"
		variant={hasToc ? 'section' : 'article'}
		class="relative py-24 sm:py-28 lg:py-32"
	>
		<div
			class:list={[
				'grid gap-8 sm:gap-10',
				hasToc ? 'lg:grid-cols-[minmax(0,1fr)_14rem] lg:items-start lg:gap-12' : ''
			]}
		>
			<article
				class="min-w-0 rounded-3xl border border-zinc-200 bg-white/70 p-5 shadow-sm backdrop-blur-md dark:border-indigo-50/10 dark:bg-zinc-950/40 sm:p-8 lg:p-10"
			>
				<ArticleHeader
					title={post.data.title}
					description={post.data.description}
					publishedAt={post.data.publishedAt}
					updatedAt={post.data.updatedAt}
					tags={post.data.tags}
					backHref="/blog/"
				/>
				<Prose>
					<Content />
				</Prose>
			</article>

			{
				hasToc && (
					<aside class="hidden lg:sticky lg:top-28 lg:block" aria-label="Article table of contents">
						<TableOfContents items={tableOfContentsItems} />
					</aside>
				)
			}
		</div>
	</Container>
</Layout>
