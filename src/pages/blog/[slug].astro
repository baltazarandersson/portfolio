---
import Layout from '@layouts/Layout.astro'
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import Container from '@components/Container.astro'
import ArticleHeader from '@components/Blog/ArticleHeader.astro'
import LanguageSwitcher from '@components/Blog/LanguageSwitcher.astro'
import ShareLinks from '@components/Blog/ShareLinks.svelte'
import Prose from '@components/Blog/Prose.astro'
import TableOfContents from '@components/Blog/TableOfContents.astro'

type Props = {
	post: CollectionEntry<'blog'>
}

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft)

	return posts.map((post) => ({
		params: { slug: post.id.replace(/\.md$/, '') },
		props: { post }
	}))
}

const { post } = Astro.props
const { Content, headings } = await render(post)

const getSlug = (id: string) => id.replace(/\.md$/, '')
const publishedPosts = await getCollection('blog', ({ data }) => !data.draft)
const languageSwitcherLinks = post.data.translationKey
	? publishedPosts
			.filter((translatedPost) => translatedPost.data.translationKey === post.data.translationKey)
			.map((translatedPost) => ({
				language: translatedPost.data.language,
				href: `/blog/${getSlug(translatedPost.id)}/`
			}))
	: []

const tableOfContentsItems = headings
	.filter((heading) => heading.depth === 2)
	.map((heading) => ({ id: heading.slug, label: heading.text }))

const hasToc = tableOfContentsItems.length > 0
const hasLanguageSwitcher = languageSwitcherLinks.length === 2
const postUrl = new URL(`/blog/${getSlug(post.id)}/`, Astro.site).href
---

<Layout
	title={`${post.data.title} | Baltazar Andersson`}
	lang={post.data.language}
	description={post.data.description}
	image={post.data.heroImage}
	type="article"
>
	<Container
		as="main"
		variant={hasToc ? 'section' : 'article'}
		class="relative py-24 sm:py-28 lg:py-32"
	>
		<div
			class:list={[
				'grid gap-8 sm:gap-10',
				hasToc ? 'lg:grid-cols-[minmax(0,1fr)_14rem] lg:items-start lg:gap-12' : ''
			]}
		>
			<article
				class="min-w-0 rounded-3xl border border-border bg-surface-elevated/70 p-5 shadow-sm backdrop-blur-md dark:border-indigo-50/10 dark:bg-zinc-950/40 sm:p-8 lg:p-10"
			>
				<ArticleHeader
					title={post.data.title}
					description={post.data.description}
					publishedAt={post.data.publishedAt}
					updatedAt={post.data.updatedAt}
					readingTime={post.data.readingTime}
					tags={post.data.tags}
					backHref="/blog/"
				>
					<div slot="actions" class="flex items-center gap-3">
						<ShareLinks
							client:idle
							url={postUrl}
							title={post.data.title}
							lang={post.data.language}
						/>
						{
							hasLanguageSwitcher && (
								<span aria-hidden="true" class="h-4 w-px bg-border dark:bg-zinc-700" />
							)
						}
						<LanguageSwitcher currentLanguage={post.data.language} links={languageSwitcherLinks} />
					</div>
				</ArticleHeader>
				<Prose>
					<Content />
				</Prose>
			</article>

			{
				hasToc && (
					<aside class="hidden lg:sticky lg:top-28 lg:block" aria-label="Article table of contents">
						<TableOfContents items={tableOfContentsItems} />
					</aside>
				)
			}
		</div>
	</Container>
</Layout>
