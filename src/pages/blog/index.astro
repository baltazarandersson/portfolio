---
import Layout from '@layouts/Layout.astro'
import { getCollection } from 'astro:content'
import Card from '@components/Card.astro'
import Container from '@components/Container.astro'
import Heading from '@components/Heading.astro'
import Text from '@components/Text.astro'
import PostCard from '@components/Blog/PostCard.astro'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
)

const getSlug = (id: string) => id.replace(/\.md$/, '')
---

<Layout title="Blog | Baltazar Andersson">
	<Container
		as="main"
		variant="article"
		class="relative space-y-12 py-24 sm:space-y-16 sm:py-28 lg:py-32"
	>
		<section class="space-y-3">
			<Text
				as="p"
				variant="caption"
				class="font-heming font-extrabold uppercase tracking-[0.24em] text-primary"
			>
				Blog
			</Text>
			<Heading as="h1" variant="section" class="text-start text-zinc-900 dark:text-indigo-50">
				Writing
			</Heading>
			<Text variant="lead" class="max-w-2xl leading-8 text-zinc-600 dark:text-zinc-300">
				Notes and articles will live here once published.
			</Text>
		</section>

		<section aria-label="Blog posts">
			{
				posts.length > 0 ? (
					<div class="grid gap-6 sm:gap-8">
						{posts.map((post, index) => (
							<PostCard
								title={post.data.title}
								description={post.data.description}
								href={`/blog/${getSlug(post.id)}/`}
								publishedAt={post.data.publishedAt}
								updatedAt={post.data.updatedAt}
								tags={post.data.tags}
								featured={index === 0}
							/>
						))}
					</div>
				) : (
					<Card
						as="section"
						variant="plain"
						class="rounded-2xl border border-dashed border-zinc-300 p-6 text-zinc-600 backdrop-blur-md dark:border-indigo-50/20 dark:text-indigo-100/70"
					>
						No published posts yet.
					</Card>
				)
			}
		</section>
	</Container>
</Layout>
