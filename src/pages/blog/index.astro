---
import Layout from '@layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
)

const getSlug = (id: string) => id.replace(/\.(md|mdx)$/, '')
const formatDate = (date: Date) =>
	date.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' })
---

<Layout title="Blog | Baltazar Andersson">
	<main class="p-layout relative mx-auto max-w-4xl py-28">
		<section class="space-y-4">
			<p class="font-heming text-sm uppercase tracking-[0.3em] text-primary">Blog</p>
			<h1 class="font-heming text-4xl text-zinc-900 dark:text-indigo-50">Writing</h1>
			<p class="max-w-2xl leading-7 text-zinc-600 dark:text-indigo-100/80">
				Notes and articles will live here once published.
			</p>
		</section>

		<section class="mt-12 space-y-6" aria-label="Blog posts">
			{
				posts.length > 0 ? (
					posts.map((post) => (
						<article class="rounded-2xl border border-zinc-200 bg-white/60 p-6 backdrop-blur dark:border-indigo-50/10 dark:bg-zinc-950/40">
							<p class="text-sm text-zinc-500 dark:text-indigo-100/60">
								{formatDate(post.data.publishedAt)}
							</p>
							<h2 class="mt-2 font-heming text-2xl text-zinc-900 dark:text-indigo-50">
								<a class="transition-colors hover:text-primary" href={`/blog/${getSlug(post.id)}/`}>
									{post.data.title}
								</a>
							</h2>
							<p class="mt-3 leading-7 text-zinc-600 dark:text-indigo-100/80">
								{post.data.description}
							</p>
						</article>
					))
				) : (
					<p class="rounded-2xl border border-dashed border-zinc-300 p-6 text-zinc-600 dark:border-indigo-50/20 dark:text-indigo-100/70">
						No published posts yet.
					</p>
				)
			}
		</section>
	</main>
</Layout>
