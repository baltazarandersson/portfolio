---
import ActionLink from '../ActionLink.astro'
import Container from '../Container.astro'
import Heading from '../Heading.astro'
import Text from '../Text.astro'

interface Props {
	eyebrow?: string
	title: string
	description: string
	meta?: string
	actionHref?: string
	actionLabel?: string
	class?: string
}

const {
	eyebrow = 'Notebook',
	title,
	description,
	meta,
	actionHref,
	actionLabel = 'Read latest posts',
	class: className = ''
} = Astro.props

const hasMetaSlot = Astro.slots.has('meta')
const hasActionSlot = Astro.slots.has('action')
---

<Container as="header" variant="article" class:list={['py-14 sm:py-20 lg:py-24', className]}>
	<div class="border-y border-border py-8 dark:border-zinc-800 sm:py-12 lg:py-16">
		<Text
			as="p"
			variant="caption"
			class="font-heming font-extrabold uppercase tracking-[0.24em] text-primary"
		>
			{eyebrow}
		</Text>
		<Heading as="h1" variant="display" class="mt-4 max-w-3xl text-start leading-tight sm:mt-5">
			{title}
		</Heading>
		<Text
			variant="lead"
			class="mt-5 max-w-2xl leading-8 text-foreground dark:text-zinc-300 sm:mt-6"
		>
			{description}
		</Text>
		{
			(meta || hasMetaSlot || actionHref || hasActionSlot) && (
				<div class="mt-8 flex flex-col gap-5 border-t border-border pt-6 dark:border-zinc-800 sm:mt-10 sm:flex-row sm:items-center sm:justify-between sm:gap-8 sm:pt-7">
					{(meta || hasMetaSlot) && (
						<div class="text-sm text-muted dark:text-zinc-400">
							{meta && <Text variant="small">{meta}</Text>}
							<slot name="meta" />
						</div>
					)}
					{(actionHref || hasActionSlot) && (
						<div class="font-heming text-sm font-bold uppercase tracking-[0.18em]">
							{actionHref && (
								<ActionLink
									href={actionHref}
									class="text-primary underline decoration-primary/40 underline-offset-4 transition hover:decoration-primary"
								>
									{actionLabel}
								</ActionLink>
							)}
							<slot name="action" />
						</div>
					)}
				</div>
			)
		}
	</div>
</Container>
