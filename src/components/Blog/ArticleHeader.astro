---
import ActionLink from '../ActionLink.astro'
import Heading from '../Heading.astro'
import Text from '../Text.astro'
import PostMeta from './PostMeta.astro'
import TagList from './TagList.astro'

type DateValue = Date | string
type BlogTag = string | { label: string; href?: string }

interface Props {
	eyebrow?: string
	title: string
	description?: string
	publishedAt: DateValue
	updatedAt?: DateValue
	readingTime?: number | string
	tags?: BlogTag[]
	backHref?: string
	backLabel?: string
	class?: string
}

const {
	eyebrow,
	title,
	description,
	publishedAt,
	updatedAt,
	readingTime,
	tags = [],
	backHref,
	backLabel = 'Back to blog',
	class: className = ''
} = Astro.props

const hasBackSlot = Astro.slots.has('back')
const hasActionsSlot = Astro.slots.has('actions')
---

<header class:list={[className]}>
	<div class="border-b border-border pb-8 dark:border-zinc-800 sm:pb-10 lg:pb-12">
		{
			(backHref || hasBackSlot || hasActionsSlot) && (
				<div class="mb-6 flex items-center justify-between gap-4 font-heming text-sm font-bold uppercase tracking-[0.18em] text-muted dark:text-zinc-400 sm:mb-8">
					<div>
						{backHref && (
							<ActionLink href={backHref} data-article-back class="transition hover:text-primary">
								{backLabel}
							</ActionLink>
						)}
						<slot name="back" />
					</div>
					<slot name="actions" />
				</div>
			)
		}
		{
			eyebrow && (
				<Text
					as="p"
					variant="caption"
					class="font-heming font-extrabold uppercase tracking-[0.2em] text-primary"
				>
					{eyebrow}
				</Text>
			)
		}
		<PostMeta
			publishedAt={publishedAt}
			updatedAt={updatedAt}
			readingTime={readingTime}
			class:list={[eyebrow ? 'mt-3' : '']}
		/>
		<Heading as="h1" variant="display" class="mt-5 text-start leading-tight sm:mt-6">
			{title}
		</Heading>
		{
			description && (
				<Text
					variant="lead"
					class="mt-5 max-w-2xl leading-8 text-foreground dark:text-zinc-300 sm:mt-6"
				>
					{description}
				</Text>
			)
		}
		<TagList tags={tags} class="mt-7 sm:mt-9" />
	</div>
</header>
