---
import ActionLink from '../ActionLink.astro'

type BlogLanguage = 'en' | 'es'

interface LanguageLink {
	language: BlogLanguage
	href: string
}

interface Props {
	currentLanguage: BlogLanguage
	links: LanguageLink[]
	class?: string
}

const { currentLanguage, links, class: className = '' } = Astro.props

const languageLabels: Record<BlogLanguage, string> = {
	en: 'EN',
	es: 'ES'
}

const orderedLinks = (['en', 'es'] as const)
	.map((language) => links.find((link) => link.language === language))
	.filter((link): link is LanguageLink => Boolean(link))

const shouldRender = orderedLinks.length === 2
---

{
	shouldRender && (
		<nav aria-label="Article language versions" class:list={[className]}>
			<ul class="flex items-center gap-3">
				{orderedLinks.map((link, index) => (
					<>
						{index > 0 && <li aria-hidden="true" class="h-4 w-px bg-border dark:bg-zinc-700" />}
						<li>
							{link.language === currentLanguage ? (
								<span aria-current="page" class="text-primary">
									{languageLabels[link.language]}
								</span>
							) : (
								<ActionLink
									href={link.href}
									class="transition hover:text-primary"
									data-astro-prefetch
								>
									{languageLabels[link.language]}
								</ActionLink>
							)}
						</li>
					</>
				))}
			</ul>
		</nav>
	)
}
