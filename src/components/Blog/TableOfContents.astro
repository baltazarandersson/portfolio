---
import ActionLink from '../ActionLink.astro'
import { useTranslations } from '@i18n/utils'

interface TocItem {
	id: string
	label: string
	depth?: 2 | 3
}

interface Props {
	items: TocItem[]
	ariaLabel?: string
	class?: string
}

const t = useTranslations(Astro.currentLocale)
const { items, ariaLabel = t('post.tocAria'), class: className = '' } = Astro.props
---

{
	items.length > 0 && (
		<nav
			aria-label={ariaLabel}
			data-blog-toc
			class:list={[
				'rounded-2xl border border-border bg-surface-elevated/60 p-5 backdrop-blur-md dark:border-indigo-50/10 dark:bg-zinc-950/40',
				className
			]}
		>
			<p class="font-heming text-xs font-bold uppercase tracking-[0.2em] text-muted dark:text-zinc-400">
				{t('post.tocTitle')}
			</p>
			<div class="relative mt-5 border-l border-border dark:border-zinc-800">
				<span
					data-toc-indicator
					aria-hidden="true"
					style="opacity: 0"
					class="pointer-events-none absolute -left-px top-0 h-0 w-0.5 rounded-full bg-primary transition-[transform,height,opacity] duration-200 ease-out motion-reduce:transition-none"
				/>
				<ol class="space-y-3 pl-5">
					{items.map((item) => (
						<li class:list={[item.depth === 3 ? 'pl-4' : '']}>
							<ActionLink
								href={`#${item.id}`}
								data-toc-link={item.id}
								class="block text-sm leading-6 text-foreground transition hover:text-primary dark:text-zinc-300"
							>
								{item.label}
							</ActionLink>
						</li>
					))}
				</ol>
			</div>
		</nav>
	)
}

<script>
	import { HEADER_HEIGHT } from '@constants/index'

	type TocTarget = { link: HTMLAnchorElement; heading: HTMLElement }
	type Cleanup = () => void

	let cleanupTablesOfContents: Cleanup | null = null

	function initBlogToc(nav: HTMLElement): Cleanup | null {
		const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'))
		const indicator = nav.querySelector<HTMLElement>('[data-toc-indicator]')
		if (links.length === 0 || !indicator) return null

		const targets = links
			.map((link) => {
				const id = link.getAttribute('data-toc-link')
				const heading = id ? document.getElementById(id) : null
				return heading ? { link, heading } : null
			})
			.filter((target): target is TocTarget => target !== null)

		if (targets.length === 0) return null

		let activeLink: HTMLAnchorElement | null = null
		let frameId = 0
		let disposed = false

		// The indicator is absolutely positioned inside the rail (its offset
		// parent), so translate relative to the rail, not the outer nav.
		const rail = indicator.parentElement as HTMLElement

		function moveIndicator(link: HTMLAnchorElement) {
			const railRect = rail.getBoundingClientRect()
			const linkRect = link.getBoundingClientRect()
			indicator!.style.height = `${linkRect.height}px`
			indicator!.style.transform = `translateY(${linkRect.top - railRect.top}px)`
			indicator!.style.opacity = '1'
		}

		function setActive(link: HTMLAnchorElement, force = false) {
			const changed = link !== activeLink
			if (!changed && !force) return
			activeLink = link

			if (changed) {
				for (const target of targets) {
					const isActive = target.link === link
					target.link.classList.toggle('text-primary', isActive)
					target.link.classList.toggle('text-foreground', !isActive)
					target.link.classList.toggle('dark:text-zinc-300', !isActive)
					if (isActive) target.link.setAttribute('aria-current', 'location')
					else target.link.removeAttribute('aria-current')
				}
			}

			moveIndicator(link)
		}

		function resolveActiveLink() {
			// Near the page bottom the trailing headings can't reach the top band,
			// so pin the last item once the viewport hits the document end.
			const reachedBottom =
				window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 2
			if (reachedBottom) return targets[targets.length - 1].link

			// Slightly below the heading's scroll-margin-top (7rem) so a clicked
			// anchor lands as the active item.
			const offset = HEADER_HEIGHT + 48
			let active = targets[0].link
			for (const target of targets) {
				if (target.heading.getBoundingClientRect().top <= offset) active = target.link
				else break
			}
			return active
		}

		function refreshActive(force = false) {
			if (disposed) return
			setActive(resolveActiveLink(), force)
		}

		let ticking = false
		function onScroll() {
			if (ticking || disposed) return
			ticking = true
			frameId = requestAnimationFrame(() => {
				refreshActive()
				ticking = false
			})
		}

		function onResize() {
			refreshActive(true)
		}

		window.addEventListener('scroll', onScroll, { passive: true })
		window.addEventListener('resize', onResize)
		window.addEventListener('hashchange', onScroll)

		refreshActive(true)
		frameId = requestAnimationFrame(() => refreshActive(true))

		return () => {
			disposed = true
			window.removeEventListener('scroll', onScroll)
			window.removeEventListener('resize', onResize)
			window.removeEventListener('hashchange', onScroll)
			if (frameId) cancelAnimationFrame(frameId)
		}
	}

	function initTablesOfContents() {
		cleanupTablesOfContents?.()
		const cleanups = Array.from(document.querySelectorAll<HTMLElement>('[data-blog-toc]'))
			.map(initBlogToc)
			.filter((cleanup): cleanup is Cleanup => cleanup !== null)

		cleanupTablesOfContents = () => cleanups.forEach((cleanup) => cleanup())
	}

	function cleanupBeforeSwap() {
		cleanupTablesOfContents?.()
		cleanupTablesOfContents = null
	}

	initTablesOfContents()
	document.addEventListener('astro:page-load', initTablesOfContents)
	document.addEventListener('astro:before-swap', cleanupBeforeSwap)
</script>
