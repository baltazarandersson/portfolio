---
import { getLang } from '@i18n/utils'
import { languages, type Lang } from '@i18n/ui'

interface Props {
	alternates: Record<Lang, string>
	class?: string
}

const { alternates, class: className = '' } = Astro.props
const current = getLang(Astro.currentLocale)
const order: Lang[] = ['en', 'es']
---

<nav
	aria-label="Language"
	class:list={['flex items-center gap-1.5 font-heming text-lg', className]}
>
	{
		order.map((lang, index) => (
			<>
				{index > 0 && (
					<span aria-hidden="true" class="text-muted dark:text-zinc-600">
						·
					</span>
				)}
				{lang === current ? (
					<span aria-current="true" class="text-orange-500 dark:text-orange-400">
						{languages[lang]}
					</span>
				) : (
					<a
						href={alternates[lang]}
						class="rounded-sm text-muted transition hover:text-orange-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-surface dark:text-zinc-400 dark:hover:text-orange-400 dark:focus-visible:ring-orange-400 dark:focus-visible:ring-offset-zinc-900"
						data-astro-prefetch
					>
						{languages[lang]}
					</a>
				)}
			</>
		))
	}
</nav>
