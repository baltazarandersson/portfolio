---
import Text from '@components/Text.astro'
import { SECTIONS, HEADER_HEIGHT, HEADER_TITLE } from '@constants/index'
import NavBar from '@components/Header/NavBar.svelte'
import ThemeSwitch from '@components/ThemeSwitch.svelte'
import Hamburguer from './Hamburguer.svelte'
import Drawer from '@components/Drawer.svelte'
import NavSection from '@components/NavSection.svelte'
import BlogTitleSwap from './BlogTitleSwap.svelte'
import LocaleSwitcher from './LocaleSwitcher.astro'
import { getLang, useTranslations } from '@i18n/utils'
import type { Lang } from '@i18n/ui'

interface Props {
	alternates: Record<Lang, string>
}

const { alternates } = Astro.props

const lang = getLang(Astro.currentLocale)
const t = useTranslations(lang)

const [presentationSection, ...otherSections] = SECTIONS

const navLabels: Record<string, string> = {
	experience: t('nav.experience'),
	projects: t('nav.projects'),
	contact: t('nav.contact'),
	blog: t('nav.blog')
}
const drawerItems = otherSections.map((section) => ({ section, label: navLabels[section] }))

const localePrefix = lang === 'es' ? '/es' : ''
const homeHref = `${localePrefix}/`
const blogHref = `${localePrefix}/blog/`

const height = `${HEADER_HEIGHT}px`
const path = Astro.url.pathname
const isBlogArticle =
	(path.startsWith('/blog/') && path !== '/blog/') ||
	(path.startsWith('/es/blog/') && path !== '/es/blog/')
---

<script>
	import { getNavSectionById } from '@utils/getNavSection'
	import { closeDrawer } from 'src/store/drawer'

	const homeNavEl = getNavSectionById('presentation')

	homeNavEl?.addEventListener('click', closeDrawer)
</script>
<header
	class="fixed z-50 flex w-full items-center justify-between border-b-2 border-border bg-surface-muted bg-opacity-80 font-heming backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-900/80 dark:bg-opacity-40"
>
	<div class="p-layout relative flex h-full w-full items-center justify-between">
		{
			isBlogArticle ? (
				<BlogTitleSwap
					client:idle
					homeHref={homeHref}
					backHref={blogHref}
					backLabel={t('post.backToBlog')}
				/>
			) : (
				<NavSection section={presentationSection} label={HEADER_TITLE} lang={lang} client:idle />
			)
		}

		<nav class="hidden items-center gap-4 md:flex lg:gap-8">
			<Text as="span" variant="p3">{`<`}</Text>
			{
				otherSections.map((section) => (
					<NavSection client:idle {section} label={navLabels[section]} lang={lang} />
				))
			}
			<LocaleSwitcher alternates={alternates} />
			<ThemeSwitch client:idle />
			<Text as="span" variant="p3">{`/ >`}</Text>
		</nav>
		<NavBar client:only />
		<div class="flex h-10 items-center gap-4 md:hidden">
			<LocaleSwitcher alternates={alternates} />
			<ThemeSwitch client:idle />
			<Hamburguer client:idle />
		</div>
	</div>
</header>
<Drawer client:idle items={drawerItems} lang={lang} />
<style define:vars={{ height }}>
	header {
		height: var(--height);
	}
</style>
