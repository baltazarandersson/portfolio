---
import Heading from '@components/Heading.astro'
import Text from '@components/Text.astro'
import Underline from '@components/Underline.astro'
import Section from '@components/Section.astro'
import type { SectionType } from 'types/index'
import { useTranslations } from '@i18n/utils'

interface Props {
	id?: SectionType
}

const { id = '' } = Astro.props
const t = useTranslations(Astro.currentLocale)
---

<Section
	class="p-layout flex flex-col items-center justify-center gap-10 md:flex-row md:justify-between md:gap-20"
	id={id}
>
	<div class="flex w-full flex-col gap-8">
		<Heading>
			{t('presentation.greeting')}
			<br class="hidden sm:block" />
			{t('presentation.intro')}{' '}
			<span class="relative">Baltazar<Underline /></span>
		</Heading>
		<Text variant="p3" class="text-center text-muted dark:text-zinc-400 sm:text-start lg:w-3/5">
			{t('presentation.lead')}
		</Text>
	</div>
</Section>
