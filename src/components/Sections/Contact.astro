---
import Heading from '@components/Heading.astro'
import Section from '@components/Section.astro'
import type { SectionType } from 'types/index'
import Socials from '@components/Socials/index.svelte'
import FileDownloadIcon from '@components/Icons/FileDownloadIcon.svelte'
import Text from '@components/Text.astro'
import ActionLink from '@components/ActionLink.astro'
import Card from '@components/Card.astro'
import { getLang, useTranslations } from '@i18n/utils'

interface Props {
	id?: SectionType
}

const { id = '' } = Astro.props
const lang = getLang(Astro.currentLocale)
const t = useTranslations(lang)
const blogHref = `${lang === 'es' ? '/es' : ''}/blog/`
---

<Section class="p-layout flex items-start" id={id}>
	<div class="mt-20 flex w-full flex-col gap-20">
		<Heading as="h2" variant="section">{t('contact.title')}</Heading>

		<div class="flex flex-col justify-center gap-12 font-heming lg:w-fit">
			<Socials
				client:idle
				class="grid grid-flow-row grid-cols-1 gap-4 lg:w-fit lg:grid-cols-2 lg:gap-8"
				labels
			/>

			<ActionLink
				href="/Baltazar%20Andersson%20CV.pdf"
				aria-label="download Baltazar's portfolio"
				target="_blank"
				class={`flex px-8 py-4 items-start justify-center gap-4 rounded-lg bg-zinc-400/10 backdrop-blur-3xl transition-all duration-200 hover:scale-105 hover:bg-amber-600/10 hover:text-orange-500 dark:bg-zinc-200/10 dark:hover:bg-amber-400/10 dark:hover:text-orange-400`}
			>
				<div class="shrink-0">
					<FileDownloadIcon client:idle />
				</div>
				<Text as="span" variant="p2">{t('contact.downloadCv')}</Text>
			</ActionLink>
		</div>

		<Card variant="plain" class="w-full lg:w-fit">
			<div
				class="flex flex-col gap-4 text-center lg:flex-row lg:items-center lg:justify-between lg:gap-8 lg:text-left"
			>
				<div>
					<Heading as="h3" variant="h3">{t('contact.readMoreTitle')}</Heading>
					<Text as="p" variant="p2" class="text-muted dark:text-zinc-400">
						{t('contact.readMoreText')}
					</Text>
				</div>
				<ActionLink
					href={blogHref}
					class="flex items-center justify-center gap-2 rounded-lg bg-orange-500 px-6 py-3 font-medium text-zinc-50 transition-colors hover:bg-orange-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-surface dark:focus-visible:ring-offset-zinc-900"
				>
					<Text as="span" variant="p2">{t('contact.goToBlog')}</Text>
				</ActionLink>
			</div>
		</Card>
	</div>
</Section>
