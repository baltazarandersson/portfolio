---
import Heading from '@components/Heading.astro'
import JobList from '@components/JobList/index.astro'
import Section from '@components/Section.astro'
import type { SectionType } from 'types/index'
import { getJobs } from '@services/jobs'
import { getLang, useTranslations } from '@i18n/utils'

interface Props {
	id?: SectionType
}

const { id = '' } = Astro.props

const lang = getLang(Astro.currentLocale)
const t = useTranslations(lang)
const jobs = await getJobs(lang)
---

<Section class="p-layout flex items-start" id={id}>
	<div class="mt-8 flex w-full max-w-4xl flex-col gap-8 md:mt-10 md:gap-10">
		<Heading as="h2" variant="section">{t('experience.title')}</Heading>
		<JobList {jobs} />
	</div>
</Section>
