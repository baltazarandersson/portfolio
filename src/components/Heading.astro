---
type HeadingTag = 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'
type HeadingVariant = 'display' | 'title' | 'section' | 'subsection' | 'eyebrow' | HeadingTag

type Props = {
	as?: HeadingTag
	variant?: HeadingVariant
	size?: HeadingVariant
	class?: string
} & Record<string, unknown>

const variantClasses: Record<HeadingVariant, string> = {
	display: 'text-3xl sm:text-5xl md:text-6xl',
	title: 'text-5xl md:text-5xl',
	section: 'text-3xl sm:text-4xl md:text-5xl',
	subsection: 'text-3xl md:text-4xl',
	eyebrow: 'text-2xl md:text-3xl',
	h6: 'text-xl md:text-2xl',
	h5: 'text-2xl md:text-3xl',
	h4: 'text-3xl md:text-4xl',
	h3: 'text-4xl md:text-5xl',
	h2: 'text-5xl md:text-5xl',
	h1: 'text-5xl md:text-6xl'
}

const headingTags: HeadingTag[] = ['h1', 'h2', 'h3', 'h4', 'h5', 'h6']
const { as, variant, size, class: className = '', ...attrs } = Astro.props as Props
const selectedVariant = variant ?? size ?? 'h1'
const Tag = as ?? (headingTags.includes(size as HeadingTag) ? (size as HeadingTag) : 'h1')
---

<Tag
	{...attrs}
	class:list={[
		'text-center font-heming font-bold tracking-widest sm:text-start',
		variantClasses[selectedVariant],
		className
	]}
>
	<slot />
</Tag>
