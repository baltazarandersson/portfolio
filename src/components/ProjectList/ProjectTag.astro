---
import type { TagType } from 'types/tags'
import Badge from '@components/Badge.astro'
import IconLink from '@components/IconLink.astro'

interface Props {
	tag: TagType
}

const {
	tag: { source, iconClass, icon, title }
} = Astro.props
---

<Badge class:list={['flex justify-center', iconClass]}>
	<IconLink href={source} ariaLabel={`Open ${title} website`} class="h-8 w-8">
		<img alt="" src={icon} class="h-8 w-8 object-contain" aria-hidden="true" />
	</IconLink>
</Badge>
