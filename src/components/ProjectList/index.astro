---
import ProjectItem from './ProjectItem.astro'
import type { ProjectType } from 'types/projects'

interface Props {
	projects: ProjectType[]
}

const { projects } = Astro.props
---

<ul
	data-project-list
	class="grid w-full grow grid-flow-row grid-cols-1 sm:grid-cols-[repeat(auto-fit,_minmax(400px,_1fr))]"
>
	{projects.map((project) => <ProjectItem {project} />)}
</ul>

<script>
	import { throttle } from '@utils/throttle'

	// On touch devices without hover the cards start with their info overlay hidden.
	// Reveal the card(s) closest to the middle of the viewport so the reader sees
	// highlighted content while scrolling. On 1-column layouts we highlight 1 card;
	// on 2-column layouts we highlight the pair in the closest row.
	// Desktop with a mouse keeps the native hover behavior.
	const setupSpotlight = () => {
		const list = document.querySelector<HTMLElement>('[data-project-list]')
		if (!list) return () => {}

		const items = Array.from(list.querySelectorAll<HTMLElement>('[data-project-item]'))
		if (items.length === 0) return () => {}

		const noHover = window.matchMedia('(hover: none)')
		const clear = () => items.forEach((item) => item.classList.remove('is-active'))

		const getColumnCount = () =>
			window.getComputedStyle(list).gridTemplateColumns.trim().split(/\s+/).length

		const update = () => {
			const columnCount = getColumnCount()
			// Only spotlight on touch devices with up to 2 columns.
			if (!noHover.matches || columnCount > 2) {
				clear()
				return
			}

			const viewportCenter = window.innerHeight / 2

			const distances = items.map((item) => {
				const rect = item.getBoundingClientRect()
				const distance = Math.abs(rect.top + rect.height / 2 - viewportCenter)
				return { item, distance }
			})

			distances.sort((a, b) => a.distance - b.distance)

			const activeItems = distances.slice(0, columnCount).map((d) => d.item)
			const activeSet = new Set(activeItems)

			items.forEach((item) => item.classList.toggle('is-active', activeSet.has(item)))
		}

		const onScroll = throttle(update, 100)
		window.addEventListener('scroll', onScroll, { passive: true })
		window.addEventListener('resize', onScroll, { passive: true })
		noHover.addEventListener('change', update)
		update()

		return () => {
			window.removeEventListener('scroll', onScroll)
			window.removeEventListener('resize', onScroll)
			noHover.removeEventListener('change', update)
			clear()
		}
	}

	let teardown = () => {}
	// Re-bind across view transitions (the project list lives on the home page).
	document.addEventListener('astro:page-load', () => {
		teardown()
		teardown = setupSpotlight()
	})
	document.addEventListener('astro:before-swap', () => teardown())
</script>
