---
import type { TagType } from 'types/tags'
import Badge from '@components/Badge.astro'
import IconLink from '@components/IconLink.astro'

interface Props {
	technologies: TagType[]
}

const { technologies } = Astro.props
---

<ul class="flex w-fit items-center justify-start gap-4 sm:justify-start">
	{
		technologies.map(({ source, iconClass, title, icon, iconDark }) => (
			<li>
				<Badge class="h-8 w-8">
					<IconLink
						href={source}
						ariaLabel={`Open ${title} website`}
						class:list={['h-8 w-8', iconClass]}
					>
						{iconDark ? (
							<>
								<img alt="" src={icon} class="object-contain dark:hidden" aria-hidden="true" />
								<img
									alt=""
									src={iconDark}
									class="hidden object-contain dark:block"
									aria-hidden="true"
								/>
							</>
						) : (
							<img alt="" src={icon} class="object-contain" aria-hidden="true" />
						)}
					</IconLink>
				</Badge>
			</li>
		))
	}
</ul>
