---
import type { TagType } from 'types/tags'
import IconLink from '@components/IconLink.astro'

interface Props {
	technologies: TagType[]
	showLabels?: boolean
}

const { technologies, showLabels = false } = Astro.props
---

<ul
	class:list={[
		'flex w-fit items-center justify-start gap-4 sm:justify-start',
		showLabels && 'w-full flex-wrap !gap-1 sm:gap-2.5'
	]}
>
	{
		technologies.map(({ source, iconClass, title, icon, iconDark, shortLabel }) => (
			<li>
				<IconLink
					href={source}
					ariaLabel={`Open ${title} website`}
					class:list={[
						showLabels
							? 'gap-1.5 rounded-full border border-border bg-surface-elevated/70 px-2.5 py-1.5 text-xs leading-none text-foreground hover:scale-100 dark:border-zinc-800 dark:bg-zinc-950/35 dark:text-zinc-300 sm:gap-2 sm:px-3 sm:text-sm'
							: 'h-8 w-8 text-foreground'
					]}
				>
					{icon ? (
						iconDark ? (
							<>
								<img
									alt=""
									src={icon}
									class:list={[
										showLabels ? 'h-3.5 w-3.5 object-contain sm:h-4 sm:w-4' : 'object-contain',
										'dark:hidden',
										iconClass
									]}
									aria-hidden="true"
								/>
								<img
									alt=""
									src={iconDark}
									class:list={[
										showLabels ? 'h-3.5 w-3.5 object-contain sm:h-4 sm:w-4' : 'object-contain',
										'hidden dark:block'
									]}
									aria-hidden="true"
								/>
							</>
						) : (
							<img
								alt=""
								src={icon}
								class:list={[
									showLabels ? 'h-3.5 w-3.5 object-contain sm:h-4 sm:w-4' : 'object-contain',
									iconClass
								]}
								aria-hidden="true"
							/>
						)
					) : (
						<span
							aria-hidden="true"
							class="font-heming text-xs font-extrabold uppercase tracking-[0.12em] text-primary"
						>
							{shortLabel ?? title.slice(0, 2)}
						</span>
					)}
					{showLabels && <span>{title}</span>}
				</IconLink>
			</li>
		))
	}
</ul>
